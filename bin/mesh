#!/usr/bin/env bash
set -euo pipefail

PROGRAM="${0##*/}"
STATE_DIR="${HOME}/.mesh/state"
LOG_DIR="${HOME}/.mesh/logs"
READ_TTL="${MESH_READ_TTL:-${SWITCHBOARD_READ_TTL:-120}}"
TMUX_ARGS_STRING="${MESH_TMUX_ARGS:-${SWITCHBOARD_TMUX_ARGS:-}}"
AUTO_OPEN="${MESH_AUTO_OPEN:-1}"

usage() {
  cat <<EOF
Usage:
  $PROGRAM list [--json]
  $PROGRAM resolve <target>
  $PROGRAM read <target> [--lines N]
  $PROGRAM context <target> [--lines N] [--all]
  $PROGRAM changes <target> [--lines N]
  $PROGRAM summary <target> [--lines N] [--all]
  $PROGRAM log <target> [--lines N]
  $PROGRAM follow <target> [--lines N] [--interval N]
  $PROGRAM send [--force] <target> <text>
  $PROGRAM ask [--force] <target> <text>
  $PROGRAM assign [--force] [--lines N] [--changes N] <target> <instruction>
  $PROGRAM broadcast --force [--except <target>] <text>
  $PROGRAM keys <target> <key...>
  $PROGRAM name <target> <title>
  $PROGRAM spawn [--title NAME] [--cwd DIR] [--right|--down] -- <command...>
  $PROGRAM workspace [--session NAME] [--count N] [--cmd CMD] [--cwd DIR] [--width N] [--height N] [--per-window N] [--detach] [--replace]
  $PROGRAM workspace [--session NAME] [--cwd DIR] [--width N] [--height N] [--per-window N] [--detach] [--replace] --agent title:command [--agent title:command ...]
  $PROGRAM focus <target>
  $PROGRAM doctor

Targets:
  %pane_id | pane_title | session:window.pane
EOF
}

subcommand_usage() {
  local subcommand="$1"
  case "$subcommand" in
    list)
      cat <<EOF
Usage:
  $PROGRAM list [--json]
EOF
      ;;
    resolve)
      cat <<EOF
Usage:
  $PROGRAM resolve <target>
EOF
      ;;
    read)
      cat <<EOF
Usage:
  $PROGRAM read <target> [--lines N]
EOF
      ;;
    context)
      cat <<EOF
Usage:
  $PROGRAM context <target> [--lines N] [--all]
EOF
      ;;
    changes)
      cat <<EOF
Usage:
  $PROGRAM changes <target> [--lines N]
EOF
      ;;
    summary)
      cat <<EOF
Usage:
  $PROGRAM summary <target> [--lines N] [--all]
EOF
      ;;
    log)
      cat <<EOF
Usage:
  $PROGRAM log <target> [--lines N]
EOF
      ;;
    follow)
      cat <<EOF
Usage:
  $PROGRAM follow <target> [--lines N] [--interval N]
EOF
      ;;
    send)
      cat <<EOF
Usage:
  $PROGRAM send [--force] <target> <text>
EOF
      ;;
    ask)
      cat <<EOF
Usage:
  $PROGRAM ask [--force] <target> <text>
EOF
      ;;
    assign)
      cat <<EOF
Usage:
  $PROGRAM assign [--force] [--lines N] [--changes N] <target> <instruction>
EOF
      ;;
    broadcast)
      cat <<EOF
Usage:
  $PROGRAM broadcast --force [--except <target>] <text>
EOF
      ;;
    keys)
      cat <<EOF
Usage:
  $PROGRAM keys <target> <key...>
EOF
      ;;
    name)
      cat <<EOF
Usage:
  $PROGRAM name <target> <title>
EOF
      ;;
    spawn)
      cat <<EOF
Usage:
  $PROGRAM spawn [--title NAME] [--cwd DIR] [--right|--down] -- <command...>
EOF
      ;;
    workspace|swarm)
      cat <<EOF
Usage:
  $PROGRAM workspace [--session NAME] [--count N] [--cmd CMD] [--cwd DIR] [--width N] [--height N] [--per-window N] [--detach] [--replace]
  $PROGRAM workspace [--session NAME] [--cwd DIR] [--width N] [--height N] [--per-window N] [--detach] [--replace] --agent title:command [--agent title:command ...]
EOF
      ;;
    focus)
      cat <<EOF
Usage:
  $PROGRAM focus <target>
EOF
      ;;
    doctor)
      cat <<EOF
Usage:
  $PROGRAM doctor
EOF
      ;;
    *)
      usage
      return 1
      ;;
  esac
}

die() {
  printf '%s\n' "$*" >&2
  exit 1
}

note() {
  printf '%s\n' "$*"
}

require_tmux() {
  command -v tmux >/dev/null 2>&1 || die "tmux is required"
  [[ -n "${TMUX:-}" ]] || tmux_cmd ls >/dev/null 2>&1 || die "tmux server is not running"
}

tmux_cmd() {
  if [[ -n "$TMUX_ARGS_STRING" ]]; then
    # shellcheck disable=SC2206
    local extra=( $TMUX_ARGS_STRING )
    tmux "${extra[@]}" "$@"
  else
    tmux "$@"
  fi
}

ensure_state_dir() {
  mkdir -p "$STATE_DIR" "$LOG_DIR"
}

mark_read() {
  ensure_state_dir
  local pane_id="$1"
  date +%s >"$STATE_DIR/${pane_id#%}.read"
}

require_recent_read() {
  local pane_id="$1"
  local stamp_file="$STATE_DIR/${pane_id#%}.read"
  [[ -f "$stamp_file" ]] || die "refusing blind write to $pane_id; read it first or pass --force"
  local now
  now="$(date +%s)"
  local last
  last="$(cat "$stamp_file")"
  (( now - last <= READ_TTL )) || die "last read for $pane_id is older than ${READ_TTL}s; read it again or pass --force"
}

pane_rows() {
  tmux_cmd list-panes -a -F '#{pane_id}|#{session_name}|#{window_index}|#{pane_index}|#{pane_title}|#{pane_start_command}|#{pane_current_path}'
}

pane_rows_in_session() {
  local session_name="$1"
  tmux_cmd list-panes -t "$session_name" -F '#{pane_id}|#{session_name}|#{window_index}|#{pane_index}|#{pane_title}|#{pane_start_command}|#{pane_current_path}'
}

safe_path_component() {
  printf '%s' "$1" | tr -cs '[:alnum:]._-' '_'
}

escape_applescript_string() {
  printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g'
}

show_session_in_terminal() {
  local session_name="$1"
  [[ "$AUTO_OPEN" == "1" ]] || return 1
  [[ "$(uname -s)" == "Darwin" ]] || return 1
  command -v osascript >/dev/null 2>&1 || return 1

  local tmux_bin attach_cmd escaped
  tmux_bin="$(command -v tmux)"
  attach_cmd="export PATH=\"$(dirname "$tmux_bin"):\$PATH\"; exec \"$tmux_bin\" attach-session -t \"$session_name\""
  escaped="$(escape_applescript_string "$attach_cmd")"
  osascript >/dev/null <<EOF
tell application "Terminal"
  activate
  do script "$escaped"
end tell
EOF
}

session_log_dir() {
  local session_name="$1"
  printf '%s/%s\n' "$LOG_DIR" "$(safe_path_component "$session_name")"
}

pane_log_path() {
  local pane_id="$1"
  local session_name
  session_name="$(current_session_name "$pane_id")"
  printf '%s/%s.log\n' "$(session_log_dir "$session_name")" "${pane_id#%}"
}

snapshot_hash_path() {
  local pane_id="$1"
  printf '%s/%s.snapshot' "$STATE_DIR" "${pane_id#%}"
}

pane_capture() {
  local pane_id="$1"
  local lines="$2"
  tmux_cmd capture-pane -p -J -t "$pane_id" -S "-$lines"
}

append_snapshot_if_changed() {
  local pane_id="$1"
  local content="$2"
  ensure_state_dir
  local hash
  hash="$(printf '%s' "$content" | cksum | awk '{print $1":"$2}')"
  local hash_path
  hash_path="$(snapshot_hash_path "$pane_id")"
  if [[ -f "$hash_path" ]] && [[ "$(cat "$hash_path")" == "$hash" ]]; then
    return
  fi
  printf '%s' "$hash" >"$hash_path"

  local log_path
  log_path="$(pane_log_path "$pane_id")"
  mkdir -p "$(dirname "$log_path")"
  local session_name pane_title pane_command pane_path
  session_name="$(current_session_name "$pane_id")"
  pane_title="$(tmux_cmd display-message -p -t "$pane_id" '#{pane_title}')"
  pane_command="$(tmux_cmd display-message -p -t "$pane_id" '#{pane_current_command}')"
  pane_path="$(tmux_cmd display-message -p -t "$pane_id" '#{pane_current_path}')"
  {
    printf '=== %s session=%s pane=%s title=%s command=%s cwd=%s ===\n' \
      "$(date '+%Y-%m-%d %H:%M:%S %Z')" \
      "$session_name" \
      "$pane_id" \
      "${pane_title:--}" \
      "$pane_command" \
      "$pane_path"
    printf '%s\n' "$content"
    printf '\n'
  } >>"$log_path"
}

capture_and_record() {
  local pane_id="$1"
  local lines="$2"
  local output
  output="$(pane_capture "$pane_id" "$lines")"
  append_snapshot_if_changed "$pane_id" "$output"
  mark_read "$pane_id"
  printf '%s\n' "$output"
}

last_signal_line() {
  awk '
    NF {
      last = $0
      if ($0 !~ /^[[:space:]]*(➜|❯|>|%|#|\$)/) {
        signal = $0
      }
    }
    END {
      if (signal != "") {
        print signal
      } else {
        print last
      }
    }
  '
}

print_indented() {
  sed 's/^/  /'
}

pane_title_value() {
  local pane_id="$1"
  tmux_cmd display-message -p -t "$pane_id" '#{pane_title}'
}

pane_command_value() {
  local pane_id="$1"
  tmux_cmd display-message -p -t "$pane_id" '#{pane_current_command}'
}

pane_path_value() {
  local pane_id="$1"
  tmux_cmd display-message -p -t "$pane_id" '#{pane_current_path}'
}

repo_root_for_path() {
  local path="$1"
  git -C "$path" rev-parse --show-toplevel 2>/dev/null || true
}

repo_branch_for_root() {
  local root="$1"
  git -C "$root" rev-parse --abbrev-ref HEAD 2>/dev/null || true
}

repo_last_commit_for_root() {
  local root="$1"
  git -C "$root" log -1 --oneline 2>/dev/null || true
}

render_repo_snapshot_for_path() {
  local path="$1"
  local lines="$2"
  local repo_root
  repo_root="$(repo_root_for_path "$path")"
  if [[ -z "$repo_root" ]]; then
    printf 'repo: none\n'
    return
  fi

  local branch last_commit
  branch="$(repo_branch_for_root "$repo_root")"
  last_commit="$(repo_last_commit_for_root "$repo_root")"
  printf 'repo: %s\n' "$repo_root"
  printf 'branch: %s\n' "${branch:-unknown}"
  printf 'head: %s\n' "${last_commit:-no commits yet}"

  local status diffstat
  status="$(git -C "$repo_root" status --short 2>/dev/null | head -n "$lines")"
  diffstat="$(git -C "$repo_root" diff --stat HEAD 2>/dev/null | head -n "$lines")"

  if [[ -n "$status" ]]; then
    printf 'status:\n'
    printf '%s\n' "$status" | print_indented
  else
    printf 'status: clean\n'
  fi

  if [[ -n "$diffstat" ]]; then
    printf 'diff:\n'
    printf '%s\n' "$diffstat" | print_indented
  fi
}

render_changes_for_pane() {
  local pane_id="$1"
  local lines="$2"
  render_repo_snapshot_for_path "$(pane_path_value "$pane_id")" "$lines"
}

render_summary_for_pane() {
  local pane_id="$1"
  local lines="$2"
  local include_target="$3"
  local include_changes="$4"
  local session_name target_title
  session_name="$(current_session_name "$pane_id")"
  target_title="$(pane_title_value "$pane_id")"

  printf 'session=%s target=%s lines=%s\n' "$session_name" "${target_title:-$pane_id}" "$lines"
  if [[ "$include_changes" == "1" ]]; then
    printf '\n'
    render_changes_for_pane "$pane_id" "$lines"
  fi

  local found=0
  local row_pane row_session window_index pane_index pane_title pane_command pane_path output recent last_line
  while IFS='|' read -r row_pane row_session window_index pane_index pane_title pane_command pane_path; do
    [[ -n "$row_pane" ]] || continue
    if [[ "$include_target" != "1" && "$row_pane" == "$pane_id" ]]; then
      continue
    fi
    found=1
    output="$(capture_and_record "$row_pane" "$lines")"
    last_line="$(printf '%s\n' "$output" | last_signal_line)"
    recent="$(printf '%s\n' "$output" | tail -n 4)"
    printf '\n'
    printf -- '--- %s (%s %s.%s, %s)\n' "${pane_title:-$row_pane}" "$row_pane" "$window_index" "$pane_index" "$pane_command"
    printf 'cwd: %s\n' "$pane_path"
    printf 'last: %s\n' "${last_line:--}"
    printf 'recent:\n'
    printf '%s\n' "$recent" | print_indented
  done < <(pane_rows_in_session "$session_name")

  if [[ "$found" != "1" ]]; then
    printf '\n'
    printf 'no sibling panes found in session %s\n' "$session_name"
  fi
}

build_assignment_packet() {
  local pane_id="$1"
  local instruction="$2"
  local lines="$3"
  local target_title
  target_title="$(pane_title_value "$pane_id")"
  cat <<EOF
You are working inside a mesh workspace.
Target worker: ${target_title:-$pane_id}

Workspace awareness:
$(render_summary_for_pane "$pane_id" "$lines" 0 1)

Assignment:
$instruction

Work in coordination with the sibling agents above. Avoid duplicating their scope, account for the shared repo state in the workspace awareness block, and report back what you changed and what you verified.
EOF
}

paste_text_to_pane() {
  local pane_id="$1"
  local text="$2"
  local buffer_name="mesh.$$.${RANDOM}"
  printf '%s' "$text" | tmux_cmd load-buffer -b "$buffer_name" -
  tmux_cmd paste-buffer -p -d -b "$buffer_name" -t "$pane_id"
  tmux_cmd delete-buffer -b "$buffer_name" >/dev/null 2>&1 || true
}

largest_pane_info() {
  local target="$1"
  tmux_cmd list-panes -t "$target" -F '#{pane_id}|#{pane_width}|#{pane_height}' \
    | awk -F'|' '
      BEGIN { best = ""; area = 0 }
      {
        current = $2 * $3
        if (current > area) {
          area = current
          best = $0
        }
      }
      END { print best }
    '
}

resolve_target() {
  local target="$1"
  [[ -n "$target" ]] || die "target is required"

  if [[ "$target" == %* ]]; then
    tmux_cmd display-message -p -t "$target" '#{pane_id}' >/dev/null 2>&1 || die "pane $target not found"
    printf '%s\n' "$target"
    return
  fi

  if [[ "$target" == *:*.* ]]; then
    tmux_cmd display-message -p -t "$target" '#{pane_id}' 2>/dev/null || die "pane target $target not found"
    return
  fi

  local matches
  matches="$(pane_rows | awk -F'|' -v q="$target" '$5 == q { print $1 }')"
  local count
  count="$(printf '%s\n' "$matches" | sed '/^$/d' | wc -l | tr -d ' ')"
  if [[ "$count" == "1" ]]; then
    printf '%s\n' "$matches"
    return
  fi
  if [[ "$count" -gt 1 ]]; then
    die "pane title '$target' is ambiguous"
  fi

  die "could not resolve target '$target'"
}

format_list_table() {
  pane_rows | while IFS='|' read -r pane_id session_name window_index pane_index pane_title current_command current_path; do
    printf '%-6s %-18s %-6s %-18s %-16s %s\n' \
      "$pane_id" \
      "$session_name" \
      "${window_index}.${pane_index}" \
      "${pane_title:--}" \
      "$current_command" \
      "$current_path"
  done
}

format_list_json() {
  pane_rows | awk -F'|' '
    BEGIN { print "["; first = 1 }
    {
      if (!first) print ","
      first = 0
      gsub(/\\/,"\\\\",$5); gsub(/"/,"\\\"",$5)
      gsub(/\\/,"\\\\",$6); gsub(/"/,"\\\"",$6)
      gsub(/\\/,"\\\\",$7); gsub(/"/,"\\\"",$7)
      printf "  {\"pane_id\":\"%s\",\"session\":\"%s\",\"address\":\"%s.%s\",\"title\":\"%s\",\"command\":\"%s\",\"cwd\":\"%s\"}", $1, $2, $3, $4, $5, $6, $7
    }
    END { print "\n]" }
  '
}

cmd_list() {
  local json=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -h|--help) subcommand_usage list; return ;;
      --json) json=1 ;;
      *) die "unknown option for list: $1" ;;
    esac
    shift
  done
  require_tmux
  if [[ "$json" == "1" ]]; then
    format_list_json
  else
    printf '%-6s %-18s %-6s %-18s %-16s %s\n' "PANE" "SESSION" "ADDR" "TITLE" "CMD" "CWD"
    format_list_table
  fi
}

cmd_read() {
  local target=""
  local lines=80
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -h|--help) subcommand_usage read; return ;;
      --lines) lines="$2"; shift ;;
      -* ) die "unknown option for read: $1" ;;
      * ) target="$1" ;;
    esac
    shift
  done
  [[ -n "$target" ]] || die "read requires a target"
  require_tmux
  local pane_id
  pane_id="$(resolve_target "$target")"
  capture_and_record "$pane_id" "$lines"
}

cmd_resolve() {
  [[ $# -eq 1 ]] || die "resolve requires a target"
  require_tmux
  local pane_id
  pane_id="$(resolve_target "$1")"
  tmux_cmd display-message -p -t "$pane_id" '#{pane_id}|#{session_name}|#{window_index}|#{pane_index}|#{pane_title}|#{pane_current_command}|#{pane_current_path}' \
    | awk -F'|' '{ printf("{\"pane_id\":\"%s\",\"session\":\"%s\",\"address\":\"%s.%s\",\"title\":\"%s\",\"command\":\"%s\",\"cwd\":\"%s\"}\n", $1, $2, $3, $4, $5, $6, $7) }'
}

cmd_context() {
  local target=""
  local lines=30
  local include_target=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -h|--help) subcommand_usage context; return ;;
      --lines) lines="$2"; shift 2 ;;
      --all) include_target=1; shift ;;
      -* ) die "unknown option for context: $1" ;;
      * ) target="$1"; shift ;;
    esac
  done

  [[ -n "$target" ]] || die "context requires a target"
  require_tmux
  local pane_id
  pane_id="$(resolve_target "$target")"
  local session_name
  session_name="$(tmux_cmd display-message -p -t "$pane_id" '#{session_name}')"
  local target_title
  target_title="$(tmux_cmd display-message -p -t "$pane_id" '#{pane_title}')"

  printf 'session=%s target=%s lines=%s\n' "$session_name" "${target_title:-$pane_id}" "$lines"

  local found=0
  local row_pane row_session window_index pane_index pane_title pane_command pane_path
  while IFS='|' read -r row_pane row_session window_index pane_index pane_title pane_command pane_path; do
    [[ -n "$row_pane" ]] || continue
    if [[ "$include_target" != "1" && "$row_pane" == "$pane_id" ]]; then
      continue
    fi
    found=1
    printf '\n'
    printf -- '--- %s (%s %s.%s, %s)\n' "${pane_title:-$row_pane}" "$row_pane" "$window_index" "$pane_index" "$pane_command"
    printf 'cwd: %s\n' "$pane_path"
    capture_and_record "$row_pane" "$lines"
  done < <(pane_rows_in_session "$session_name")

  if [[ "$found" != "1" ]]; then
    printf '\n'
    printf 'no sibling panes found in session %s\n' "$session_name"
  fi
}

cmd_summary() {
  local target=""
  local lines=12
  local include_target=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -h|--help) subcommand_usage summary; return ;;
      --lines) lines="$2"; shift 2 ;;
      --all) include_target=1; shift ;;
      -* ) die "unknown option for summary: $1" ;;
      * ) target="$1"; shift ;;
    esac
  done

  [[ -n "$target" ]] || die "summary requires a target"
  require_tmux
  local pane_id
  pane_id="$(resolve_target "$target")"
  render_summary_for_pane "$pane_id" "$lines" "$include_target" 1
}

cmd_changes() {
  local target=""
  local lines=20
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -h|--help) subcommand_usage changes; return ;;
      --lines) lines="$2"; shift 2 ;;
      -* ) die "unknown option for changes: $1" ;;
      * ) target="$1"; shift ;;
    esac
  done
  [[ -n "$target" ]] || die "changes requires a target"
  require_tmux
  local pane_id
  pane_id="$(resolve_target "$target")"
  printf 'target=%s\n' "$target"
  render_changes_for_pane "$pane_id" "$lines"
}

cmd_log() {
  local target=""
  local lines=80
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -h|--help) subcommand_usage log; return ;;
      --lines) lines="$2"; shift 2 ;;
      -* ) die "unknown option for log: $1" ;;
      * ) target="$1"; shift ;;
    esac
  done
  [[ -n "$target" ]] || die "log requires a target"
  require_tmux
  local pane_id
  pane_id="$(resolve_target "$target")"
  local log_path
  log_path="$(pane_log_path "$pane_id")"
  [[ -f "$log_path" ]] || die "no saved snapshots for $target yet"
  tail -n "$lines" "$log_path"
}

cmd_follow() {
  local target=""
  local lines=30
  local interval=1
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -h|--help) subcommand_usage follow; return ;;
      --lines) lines="$2"; shift 2 ;;
      --interval) interval="$2"; shift 2 ;;
      -* ) die "unknown option for follow: $1" ;;
      * ) target="$1"; shift ;;
    esac
  done
  [[ -n "$target" ]] || die "follow requires a target"
  [[ "$lines" =~ ^[0-9]+$ ]] || die "--lines must be a positive integer"
  [[ "$interval" =~ ^[0-9]+$ ]] || die "--interval must be a positive integer"
  (( interval >= 1 )) || die "--interval must be at least 1"
  require_tmux
  local pane_id
  pane_id="$(resolve_target "$target")"
  local last_hash=""
  while true; do
    local output hash
    output="$(pane_capture "$pane_id" "$lines")"
    hash="$(printf '%s' "$output" | cksum | awk '{print $1":"$2}')"
    if [[ "$hash" != "$last_hash" ]]; then
      printf '=== %s %s ===\n' "$(date '+%Y-%m-%d %H:%M:%S')" "$target"
      printf '%s\n\n' "$output"
      append_snapshot_if_changed "$pane_id" "$output"
      mark_read "$pane_id"
      last_hash="$hash"
    fi
    sleep "$interval"
  done
}

cmd_assign() {
  local force=0
  local lines=12
  local change_lines=20
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -h|--help) subcommand_usage assign; return ;;
      --force) force=1; shift ;;
      --lines) lines="$2"; shift 2 ;;
      --changes) change_lines="$2"; shift 2 ;;
      * ) break ;;
    esac
  done
  local target="${1:-}"
  shift || true
  local instruction="${*:-}"
  [[ -n "$target" ]] || die "assign requires a target"
  [[ -n "$instruction" ]] || die "assign requires an instruction"
  require_tmux
  local pane_id
  pane_id="$(resolve_target "$target")"
  if [[ "$force" != "1" ]]; then
    require_recent_read "$pane_id"
  fi
  local packet
  packet="$(build_assignment_packet "$pane_id" "$instruction" "$lines" "$change_lines")"
  paste_text_to_pane "$pane_id" "$packet"
  tmux_cmd send-keys -t "$pane_id" Enter
}

cmd_send_common() {
  local submit="$1"
  shift
  local force=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -h|--help)
        if [[ "$submit" == "1" ]]; then
          subcommand_usage ask
        else
          subcommand_usage send
        fi
        return
        ;;
      --force) force=1; shift ;;
      * ) break ;;
    esac
  done
  local target="${1:-}"
  shift || true
  local text="${*:-}"
  [[ -n "$target" ]] || die "target is required"
  [[ -n "$text" ]] || die "text is required"
  require_tmux
  local pane_id
  pane_id="$(resolve_target "$target")"
  if [[ "$force" != "1" ]]; then
    require_recent_read "$pane_id"
  fi
  paste_text_to_pane "$pane_id" "$text"
  if [[ "$submit" == "1" ]]; then
    tmux_cmd send-keys -t "$pane_id" Enter
  fi
}

cmd_broadcast() {
  local force=0
  local except=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -h|--help) subcommand_usage broadcast; return ;;
      --force) force=1; shift ;;
      --except) except="$2"; shift 2 ;;
      * ) break ;;
    esac
  done
  [[ "$force" == "1" ]] || die "broadcast requires --force"
  [[ $# -gt 0 ]] || die "broadcast requires text"
  require_tmux
  local text="$*"
  local except_pane=""
  if [[ -n "$except" ]]; then
    except_pane="$(resolve_target "$except")"
  fi

  local sent=0
  local pane_id
  while IFS= read -r pane_id; do
    [[ -n "$pane_id" ]] || continue
    [[ "$pane_id" == "$except_pane" ]] && continue
    paste_text_to_pane "$pane_id" "$text"
    tmux_cmd send-keys -t "$pane_id" Enter
    sent=$((sent + 1))
  done < <(pane_rows | cut -d'|' -f1)

  printf 'sent to %s panes\n' "$sent"
}

cmd_keys() {
  if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
    subcommand_usage keys
    return
  fi
  [[ $# -ge 2 ]] || die "keys requires a target and at least one key"
  require_tmux
  local pane_id
  pane_id="$(resolve_target "$1")"
  shift
  tmux_cmd send-keys -t "$pane_id" "$@"
}

cmd_name() {
  if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
    subcommand_usage name
    return
  fi
  [[ $# -eq 2 ]] || die "name requires a target and a title"
  require_tmux
  local pane_id
  pane_id="$(resolve_target "$1")"
  tmux_cmd select-pane -t "$pane_id" -T "$2"
}

cmd_focus() {
  if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
    subcommand_usage focus
    return
  fi
  [[ $# -eq 1 ]] || die "focus requires a target"
  require_tmux
  local pane_id
  pane_id="$(resolve_target "$1")"
  tmux_cmd select-pane -t "$pane_id"
}

cmd_spawn() {
  local title=""
  local cwd="${PWD}"
  local direction="right"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -h|--help) subcommand_usage spawn; return ;;
      --title) title="$2"; shift 2 ;;
      --cwd) cwd="$2"; shift 2 ;;
      --right) direction="right"; shift ;;
      --down) direction="down"; shift ;;
      --) shift; break ;;
      *) die "unknown option for spawn: $1" ;;
    esac
  done
  [[ $# -gt 0 ]] || die "spawn requires a command after --"
  require_tmux
  local flag="-h"
  [[ "$direction" == "down" ]] && flag="-v"
  local pane_id
  pane_id="$(tmux_cmd split-window -P -F '#{pane_id}' "$flag" -c "$cwd" "$*")"
  if [[ -n "$title" ]]; then
    tmux_cmd select-pane -t "$pane_id" -T "$title"
  fi
  tmux_cmd select-layout -E
  printf '%s\n' "$pane_id"
}

window_pane_count() {
  local target="$1"
  tmux_cmd list-panes -t "$target" -F '#{pane_id}' | sed '/^$/d' | wc -l | tr -d ' '
}

current_window_id() {
  local target="$1"
  tmux_cmd display-message -p -t "$target" '#{window_id}'
}

current_session_name() {
  local target="$1"
  tmux_cmd display-message -p -t "$target" '#{session_name}'
}

current_window_size() {
  local target="$1"
  tmux_cmd display-message -p -t "$target" '#{window_width}|#{window_height}'
}

mesh_window_name() {
  printf 'mesh-%02d\n' "$1"
}

lock_window_name() {
  local target="$1"
  local name="$2"
  tmux_cmd set-window-option -q -t "$target" automatic-rename off
  tmux_cmd set-window-option -q -t "$target" allow-rename off
  tmux_cmd rename-window -t "$target" "$name"
}

recommended_per_window() {
  local width="$1"
  local height="$2"
  local requested="$3"
  local min_pane_width=40
  local min_pane_height=12
  local cols=$(( width / min_pane_width ))
  local rows=$(( height / min_pane_height ))
  (( cols < 1 )) && cols=1
  (( rows < 1 )) && rows=1
  local capacity=$(( cols * rows ))
  (( capacity < 2 )) && capacity=2
  if (( requested < capacity )); then
    printf '%s\n' "$requested"
  else
    printf '%s\n' "$capacity"
  fi
}

collapse_window_to_pane() {
  local window_target="$1"
  local keep_pane="$2"
  local pane_id
  while IFS= read -r pane_id; do
    [[ -n "$pane_id" ]] || continue
    [[ "$pane_id" == "$keep_pane" ]] && continue
    tmux_cmd kill-pane -t "$pane_id"
  done < <(tmux_cmd list-panes -t "$window_target" -F '#{pane_id}')
}

create_workspace_window() {
  local session_name="$1"
  local window_name="$2"
  local cwd="$3"
  local command="$4"
  tmux_cmd new-window -d -P -F '#{window_id}' -t "$session_name" -n "$window_name" -c "$cwd" "$command"
}

cmd_workspace() {
  local session_name="swarm"
  local session_explicit=0
  local count=10
  local cwd="${PWD}"
  local attach=1
  local replace=0
  local default_cmd="${SHELL:-zsh}"
  local width=240
  local height=70
  local per_window=10
  local specs=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -h|--help) subcommand_usage workspace; return ;;
      --session) session_name="$2"; session_explicit=1; shift 2 ;;
      --count) count="$2"; shift 2 ;;
      --cmd) default_cmd="$2"; shift 2 ;;
      --cwd) cwd="$2"; shift 2 ;;
      --width) width="$2"; shift 2 ;;
      --height) height="$2"; shift 2 ;;
      --per-window) per_window="$2"; shift 2 ;;
      --attach) attach=1; shift ;;
      --detach) attach=0; shift ;;
      --replace) replace=1; shift ;;
      --agent) specs+=("$2"); shift 2 ;;
      *) die "unknown option for workspace: $1" ;;
    esac
  done

  command -v tmux >/dev/null 2>&1 || die "tmux is required"
  [[ "$count" =~ ^[0-9]+$ ]] || die "--count must be a positive integer"
  (( count >= 1 )) || die "--count must be at least 1"
  [[ "$width" =~ ^[0-9]+$ ]] || die "--width must be a positive integer"
  [[ "$height" =~ ^[0-9]+$ ]] || die "--height must be a positive integer"
  [[ "$per_window" =~ ^[0-9]+$ ]] || die "--per-window must be a positive integer"
  (( width >= 80 )) || die "--width must be at least 80"
  (( height >= 24 )) || die "--height must be at least 24"
  (( per_window >= 2 )) || die "--per-window must be at least 2"

  local inside_tmux=0
  [[ -n "${TMUX:-}" ]] && inside_tmux=1

  if [[ "${#specs[@]}" -eq 0 ]]; then
    local first_title="lead"
    if [[ "$inside_tmux" != "1" || "$attach" != "1" ]]; then
      specs+=("${first_title}:$default_cmd")
    else
      specs+=("${first_title}:__mesh_current_pane__")
    fi
    local i
    for (( i = 2; i <= count; i++ )); do
      specs+=("agent-$(printf '%02d' "$i"):$default_cmd")
    done
  fi

  local layout_width="$width"
  local layout_height="$height"
  local current_pane=""
  local current_window=""
  local current_session=""
  local effective_per_window="$per_window"

  if [[ "$inside_tmux" == "1" && "$attach" == "1" ]]; then
    current_pane="$(tmux_cmd display-message -p '#{pane_id}')"
    current_window="$(current_window_id "$current_pane")"
    current_session="$(current_session_name "$current_pane")"

    if [[ "$session_explicit" == "1" ]]; then
      if [[ "$session_name" != "$current_session" ]]; then
        if tmux_cmd has-session -t "$session_name" >/dev/null 2>&1; then
          die "session '$session_name' already exists; switch to it or choose another name"
        fi
        tmux_cmd rename-session -t "$current_session" "$session_name"
        current_session="$session_name"
      fi
    else
      session_name="$current_session"
    fi

    IFS='|' read -r layout_width layout_height < <(current_window_size "$current_pane")
    effective_per_window="$(recommended_per_window "$layout_width" "$layout_height" "$per_window")"

    if [[ "$replace" == "1" ]]; then
      collapse_window_to_pane "$current_window" "$current_pane"
      local window_id window_name
      while IFS='|' read -r window_id window_name; do
        [[ -n "$window_id" ]] || continue
        [[ "$window_id" == "$current_window" ]] && continue
        [[ "$window_name" == mesh-* ]] && tmux_cmd kill-window -t "$window_id"
      done < <(tmux_cmd list-windows -t "$current_session" -F '#{window_id}|#{window_name}')
    else
      local existing_panes
      existing_panes="$(window_pane_count "$current_window")"
      (( existing_panes == 1 )) || die "current tmux window already has ${existing_panes} panes; use --replace to rebuild the workspace around the current lead pane"
      local existing_mesh_windows
      existing_mesh_windows="$(tmux_cmd list-windows -t "$current_session" -F '#{window_name}' | awk '/^mesh-/{count++} END{print count+0}')"
      (( existing_mesh_windows == 0 )) || die "current session already has a mesh workspace; use --replace to rebuild it around the current lead pane"
    fi
  else
    effective_per_window="$(recommended_per_window "$layout_width" "$layout_height" "$per_window")"
    if tmux_cmd has-session -t "$session_name" >/dev/null 2>&1; then
      if [[ "$replace" == "1" ]]; then
        tmux_cmd kill-session -t "$session_name"
      else
        die "session '$session_name' already exists; pass --replace to recreate it"
      fi
    fi
  fi

  local first=1
  local pane_id=""
  local window_target=""
  local window_number=1
  local spec title command
  for spec in "${specs[@]}"; do
    title="${spec%%:*}"
    command="${spec#*:}"
    [[ -n "$title" ]] || die "agent title cannot be empty"
    [[ -n "$command" ]] || die "agent command cannot be empty"

    if [[ "$first" == "1" && "$inside_tmux" == "1" && "$attach" == "1" ]]; then
      pane_id="$current_pane"
      window_target="$current_window"
      window_number=1
      tmux_cmd select-pane -t "$pane_id" -T "$title"
      lock_window_name "$window_target" "$(mesh_window_name "$window_number")"
      first=0
      continue
    fi

    if [[ "$first" == "1" ]]; then
      pane_id="$(tmux_cmd new-session -d -P -F '#{pane_id}' -x "$width" -y "$height" -s "$session_name" -n "$(mesh_window_name 1)" -c "$cwd" "$command")"
      window_target="$(current_window_id "$pane_id")"
      lock_window_name "$window_target" "$(mesh_window_name 1)"
      first=0
      window_number=1
    elif [[ "$(window_pane_count "$window_target")" -ge "$effective_per_window" ]]; then
      window_number=$((window_number + 1))
      window_target="$(create_workspace_window "$session_name" "$(mesh_window_name "$window_number")" "$cwd" "$command")"
      lock_window_name "$window_target" "$(mesh_window_name "$window_number")"
      pane_id="$(tmux_cmd list-panes -t "$window_target" -F '#{pane_id}' | head -n 1)"
    else
      local info target_pane target_width target_height split_flag
      info="$(largest_pane_info "$window_target")"
      target_pane="${info%%|*}"
      target_width="$(printf '%s' "$info" | cut -d'|' -f2)"
      target_height="$(printf '%s' "$info" | cut -d'|' -f3)"
      split_flag="-v"
      if [[ "$target_width" -ge $(( target_height * 16 / 10 )) ]]; then
        split_flag="-h"
      fi
      pane_id="$(tmux_cmd split-window -d -P -F '#{pane_id}' "$split_flag" -t "$target_pane" -c "$cwd" "$command")"
    fi
    tmux_cmd select-pane -t "$pane_id" -T "$title"
  done

  local window_id
  while IFS= read -r window_id; do
    [[ -n "$window_id" ]] || continue
    tmux_cmd select-layout -t "$window_id" tiled >/dev/null || true
  done < <(tmux_cmd list-windows -t "$session_name" -F '#{window_id}|#{window_name}' | awk -F'|' '$2 ~ /^mesh-/ { print $1 }')

  tmux_cmd display-message -t "$session_name" "mesh workspace ready: ${#specs[@]} panes"

  local mesh_windows
  mesh_windows="$(tmux_cmd list-windows -t "$session_name" -F '#{window_name}' | awk '/^mesh-/{count++} END{print count+0}')"

  if [[ "$attach" == "1" ]]; then
    if [[ -n "${TMUX:-}" ]]; then
      tmux_cmd select-window -t "${session_name}:$(mesh_window_name 1)"
      [[ -n "$current_pane" ]] && tmux_cmd select-pane -t "$current_pane" >/dev/null 2>&1 || true
      note "session=${session_name} panes=${#specs[@]} windows=${mesh_windows} visible-window=$(mesh_window_name 1) per-window=${effective_per_window}"
      if (( mesh_windows > 1 )); then
        note "agents were split across ${mesh_windows} windows to fit the current tmux size; use Alt-. and Alt-, to move between mesh windows"
      fi
      return
    fi
    if show_session_in_terminal "$session_name"; then
      note "opened session=${session_name} in a new Terminal window"
      note "the current lead was started outside tmux, so it is not part of that visible workspace. For a lead-preserving workspace, start tmux first and relaunch the lead inside it."
      return
    fi
    if [[ -t 0 && -t 1 ]]; then
      tmux_cmd attach-session -t "$session_name"
      return
    fi
  fi

  printf 'session=%s panes=%s windows=%s attach=%s\n' \
    "$session_name" \
    "${#specs[@]}" \
    "$mesh_windows" \
    "tmux attach-session -t $session_name"
  tmux_cmd list-panes -t "$session_name" -F '#{pane_id}|#{window_name}|#{pane_index}|#{pane_title}|#{pane_start_command}|#{pane_current_path}' \
    | while IFS='|' read -r pane_id window_index pane_index pane_title pane_command pane_path; do
        [[ "$window_index" == mesh-* ]] || continue
        printf '%-6s %-12s %-16s %-16s %s\n' "$pane_id" "${window_index}.${pane_index}" "$pane_title" "$pane_command" "$pane_path"
      done
}

cmd_doctor() {
  local self_path repo_mesh sync_state
  self_path="$(cd "$(dirname "$0")" && pwd)/$(basename "$0")"
  repo_mesh="$(pwd)/bin/mesh"
  sync_state="unknown"

  printf 'program: %s\n' "$PROGRAM"
  printf 'binary: %s\n' "$self_path"
  if command -v tmux >/dev/null 2>&1; then
    printf 'tmux: %s\n' "$(command -v tmux)"
  else
    printf 'tmux: missing\n'
  fi
  if tmux_cmd ls >/dev/null 2>&1; then
    printf 'server: running\n'
  else
    printf 'server: not running\n'
  fi
  if [[ -f "${HOME}/.config/tmux/tmux.conf" ]]; then
    printf 'config: %s\n' "${HOME}/.config/tmux/tmux.conf"
  else
    printf 'config: missing\n'
  fi
  if [[ -f "${HOME}/.mesh/tmux.conf" ]]; then
    printf 'managed-layer: installed\n'
  else
    printf 'managed-layer: missing\n'
  fi
  if [[ -f "$repo_mesh" ]]; then
    if cmp -s "$self_path" "$repo_mesh"; then
      sync_state="repo-local binary matches"
    else
      sync_state="repo-local binary differs; use ./bin/mesh or rerun bash ./install.sh"
    fi
    printf 'repo-sync: %s\n' "$sync_state"
  fi
  printf 'logs: %s\n' "$LOG_DIR"
  if [[ -n "${TMUX:-}" ]]; then
    printf 'inside-tmux: yes\n'
    printf 'current-session: %s\n' "$(tmux_cmd display-message -p '#{session_name}')"
  else
    printf 'inside-tmux: no\n'
  fi
}

main() {
  local command="${1:-}"
  [[ -n "$command" ]] || { usage; exit 1; }
  shift || true
  case "$command" in
    help)
      if [[ $# -gt 0 ]]; then
        subcommand_usage "$1"
      else
        usage
      fi
      ;;
    list) cmd_list "$@" ;;
    resolve) cmd_resolve "$@" ;;
    read) cmd_read "$@" ;;
    context) cmd_context "$@" ;;
    changes) cmd_changes "$@" ;;
    summary) cmd_summary "$@" ;;
    log) cmd_log "$@" ;;
    follow) cmd_follow "$@" ;;
    assign) cmd_assign "$@" ;;
    send) cmd_send_common 0 "$@" ;;
    ask) cmd_send_common 1 "$@" ;;
    broadcast) cmd_broadcast "$@" ;;
    keys) cmd_keys "$@" ;;
    name) cmd_name "$@" ;;
    spawn) cmd_spawn "$@" ;;
    workspace|swarm) cmd_workspace "$@" ;;
    focus) cmd_focus "$@" ;;
    doctor) cmd_doctor ;;
    help|-h|--help) usage ;;
    *) die "unknown command: $command" ;;
  esac
}

main "$@"
